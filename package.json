{
  "name": "jules-mcp-server",
  "version": "0.3.0",
  "description": "MCP server for Jules REST API",
  "type": "module",
  "bin": {
    "jules-mcp": "./dist/index.js"
  },
  "files": [
    "dist",
    "lib",
    "scripts",
    "README.md",
    ".env.example"
  ],
  "scripts": {
    "build": "node scripts/build.mjs",
    "start": "node dist/index.js",
    "start:http": "deno run --allow-net --allow-env --allow-read http.js",
    "check": "node --check index.js && node --check lib/server.js && node --check scripts/smoke-test.mjs && node --check scripts/build.mjs",
    "test:smoke": "npm run build && node --env-file=.env scripts/smoke-test.mjs"
  },
  "keywords": [
    "mcp",
    "jules",
    "model-context-protocol",
    "perplexity"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.25.76"
  }
}
