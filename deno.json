{
  "name": "jules-mcp-http",
  "version": "0.3.0",
  "exports": "./http.js",
  "description": "Jules MCP server — HTTP entrypoint for Perplexity remote connector",
  "nodeModulesDir": "auto",
  "tasks": {
    "start": "deno run --allow-net --allow-env http.js",
    "dev": "deno run --allow-net --allow-env --watch http.js"
  },
  "lint": {
    "rules": {
      "exclude": ["no-explicit-any"]
    }
  }
}
