{
  "name": "jules-mcp-perplexity",
  "version": "1.0.0",
  "exports": "./perplexity.js",
  "description": "Jules MCP server — Perplexity remote connector entrypoint",
  "nodeModulesDir": "auto",
  "tasks": {
    "start": "deno run --allow-net --allow-env perplexity.js",
    "dev": "deno run --allow-net --allow-env --watch perplexity.js",
    "start:local": "deno run --allow-net --allow-env http.js"
  },
  "lint": {
    "rules": {
      "exclude": ["no-explicit-any"]
    }
  }
}
